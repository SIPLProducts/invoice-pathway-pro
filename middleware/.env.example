# --- SAP BTP connection ---
SAP_BASE_URL=https://fa530628-e5cb-4817-8c70-9991654babd5.abap-web.us10.hana.ondemand.com
SAP_SERVICE_PATH=/sap/opu/odata4/sap/zui_gate_service/srvd_a2x/sap/zui_gate_service/0001
SAP_CLIENT=100

# --- Auth mode ---
# "basic"  -> SAP_USER + SAP_PASSWORD (only works if the tenant accepts Basic
#             auth for a service user. IDP-protected BTP tenants will redirect
#             to OAuth login and Basic will fail with sap_auth_redirect).
# "bearer" -> sends "Authorization: Bearer <SAP_BEARER_TOKEN>" instead.
SAP_AUTH_MODE=basic
SAP_USER=YOUR_BTP_USER
SAP_PASSWORD=YOUR_BTP_PASSWORD
SAP_BEARER_TOKEN=

# --- Server ---
PORT=8080
# Comma-separated list of allowed browser origins. Use * for local dev / Lovable preview.
ALLOWED_ORIGINS=*
