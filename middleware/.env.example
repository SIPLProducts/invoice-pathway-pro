# --- SAP BTP connection ---
SAP_BASE_URL=https://fa530628-e5cb-4817-8c70-9991654babd5.abap-web.us10.hana.ondemand.com
SAP_SERVICE_PATH=/sap/opu/odata4/sap/zui_gate_service/srvd_a2x/sap/zui_gate_service/0001
SAP_CLIENT=100

# --- Auth mode ---
# "basic"           -> SAP_USER + SAP_PASSWORD. Stateful tenants that issue
#                      JSESSIONID/__VCAP_ID__ cookies on first call. Middleware
#                      auto-logs in once and reuses cookies for ~4h.
# "basic_stateless" -> SAP_USER + SAP_PASSWORD. Stateless tenants that do NOT
#                      issue session cookies. Middleware sends
#                      "Authorization: Basic <user:pass>" on EVERY request.
#                      Use this if "basic" mode fails with sap_no_cookies.
# "bearer"          -> sends "Authorization: Bearer <SAP_BEARER_TOKEN>" (static token).
# "oauth_cc"        -> middleware fetches an access token via OAuth 2.0
#                      client_credentials grant from SAP_OAUTH_TOKEN_URL using
#                      SAP_OAUTH_CLIENT_ID / SAP_OAUTH_CLIENT_SECRET, caches it,
#                      and auto-refreshes. Recommended for ABAP Environment
#                      (Steampunk) tenants with a proper Communication Arrangement.
SAP_AUTH_MODE=basic_stateless

# Basic auth (Communication User)
SAP_USER=YOUR_COMMUNICATION_USER
SAP_PASSWORD=YOUR_COMMUNICATION_PASSWORD

# Static bearer
SAP_BEARER_TOKEN=

# OAuth client_credentials (from a Communication Arrangement set to OAuth 2.0)
SAP_OAUTH_TOKEN_URL=
SAP_OAUTH_CLIENT_ID=
SAP_OAUTH_CLIENT_SECRET=

# --- Server ---
PORT=8080
# Comma-separated list of allowed browser origins. Use * for local dev / Lovable preview.
ALLOWED_ORIGINS=*

# --- SAP session auto-management (Basic auth mode only) ---
# How long the auto-fetched JSESSIONID/__VCAP_ID__ cookies are considered valid
# before the middleware proactively re-logs in. Real expiry is enforced by SAP;
# this is just our safe upper bound. Default 4 hours.
SAP_SESSION_TTL_HOURS=4
# Set to 0 to silence the per-call "[SAP] …" session lifetime logs.
SAP_SESSION_LOG=1
